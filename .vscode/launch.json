{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug parseq on GPU0",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_save_error_analysis.py",
            "args": ["pretrained=parseq"],
